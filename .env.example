# Copy to .env and fill in. Secrets & credentials ONLY — everything else (backends,
# endpoints, model picks, ports, tuning) lives in docker-compose.yml's ${VAR:-default}
# fallbacks. The values below are the insecure dev defaults; OVERRIDE them in prod.

# ----- LiteLLM gateway master key. The api authenticates to the gateway with it.
LITELLM_MASTER_KEY=sk-tenir-master

# ----- Hugging Face token for gated/rate-limited model downloads (Voxtral is gated).
HF_TOKEN=

# ----- Multi-user auth. API_AUTH_SECRET MUST be overridden — the api refuses to boot
# with the default. Set the bootstrap admin to seed a first login.
API_AUTH_SECRET=dev-insecure-change-me
API_AUTH_ADMIN_USERNAME=
API_AUTH_ADMIN_PASSWORD=
API_AUTH_ADMIN_HOUSEHOLD=default
