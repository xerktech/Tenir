{
  "package_id": "com.tenir.local",
  "edition": "202601",
  "name": "Tenir",
  "version": "0.1.1",
  "min_app_version": "2.0.0",
  "min_sdk_version": "0.0.10",
  "entrypoint": "index.html",
  "permissions": [
    {
      "name": "g2-microphone",
      "desc": "Captures speech for live transcription."
    },
    {
      "name": "phone-microphone",
      "desc": "Alternate capture for seated/table conversations."
    },
    {
      "name": "network",
      "desc": "Streams audio for live transcription.",
      "whitelist": ["https://localhost", "wss://localhost"]
    }
  ],
  "supported_languages": ["en", "es"]
}
